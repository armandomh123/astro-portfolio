---
import { SOCIAL_LINKS, NAME } from "../consts";
const today = new Date();
---

<footer class="section container">
	<div class="footer-content">
		<div class="footer-info">
			<span class="logo">{NAME}</span>
			<p>Construyendo el futuro de la web, un pixel a la vez.</p>
		</div>
		<div class="footer-social">
			<a href={SOCIAL_LINKS.github} target="_blank">GitHub</a>
			<a href={SOCIAL_LINKS.linkedin} target="_blank">LinkedIn</a>
			<a href={SOCIAL_LINKS.twitter} target="_blank">Twitter</a>
		</div>
	</div>
	<div class="footer-bottom">
		&copy; {today.getFullYear()} {NAME}. Todos los derechos reservados.
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border-color);
		margin-top: var(--s-16);
		padding-bottom: var(--s-16);
	}
	.footer-content {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: var(--s-12);
	}
	.footer-info .logo {
		font-weight: 800;
		font-size: 1.5rem;
		display: block;
		margin-bottom: var(--s-2);
		color: var(--text-primary);
		letter-spacing: -0.04em;
	}
	.footer-info p {
		max-width: 300px;
		font-size: 0.95rem;
	}
	.footer-social {
		display: flex;
		gap: var(--s-8);
	}
	.footer-social a {
		color: var(--text-secondary);
		font-weight: 600;
		font-size: 0.9rem;
		transition: all var(--transition-fast);
	}
	.footer-social a:hover {
		color: var(--accent-start);
		transform: translateY(-2px);
	}
	.footer-bottom {
		text-align: center;
		color: var(--text-muted);
		font-size: 0.85rem;
		padding-top: var(--s-8);
		border-top: 1px solid var(--border-color);
	}
	@media (max-width: 768px) {
		.footer-content {
			flex-direction: column;
			gap: var(--s-8);
			text-align: center;
			align-items: center;
		}
		.footer-social {
			gap: var(--s-6);
		}
	}
</style>
