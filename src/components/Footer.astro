---
import { SOCIAL_LINKS, NAME } from "../consts";
const today = new Date();
---

<footer class="section container">
	<div class="footer-content">
		<div class="footer-info">
			<span class="logo">{NAME}</span>
			<p>Construyendo el futuro de la web, un pixel a la vez.</p>
		</div>
		<div class="footer-social">
			<a href={SOCIAL_LINKS.github} target="_blank">GitHub</a>
			<a href={SOCIAL_LINKS.linkedin} target="_blank">LinkedIn</a>
			<a href={SOCIAL_LINKS.twitter} target="_blank">Twitter</a>
		</div>
	</div>
	<div class="footer-bottom">
		&copy; {today.getFullYear()} {NAME}. Todos los derechos reservados.
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border-color);
		margin-top: 4rem;
		padding-bottom: 4rem;
	}
	.footer-content {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 3rem;
	}
	.footer-info .logo {
		font-weight: 800;
		font-size: 1.5rem;
		display: block;
		margin-bottom: 0.5rem;
	}
	.footer-info p {
		max-width: 300px;
	}
	.footer-social {
		display: flex;
		gap: 2rem;
	}
	.footer-social a {
		color: var(--text-secondary);
		font-weight: 500;
	}
	.footer-social a:hover {
		color: var(--accent-start);
	}
	.footer-bottom {
		text-align: center;
		color: var(--text-muted);
		font-size: 0.9rem;
	}
	@media (max-width: 768px) {
		.footer-content {
			flex-direction: column;
			gap: 2rem;
			text-align: center;
			align-items: center;
		}
		.footer-social {
			gap: 1.5rem;
		}
	}
</style>
