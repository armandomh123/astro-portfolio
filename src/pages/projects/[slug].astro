---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BackgroundVectors from '../../components/BackgroundVectors.astro';
import { PROJECTS } from '../../consts';


export async function getStaticPaths() {
	return PROJECTS.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

const { project } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`${project.title} - Jesús Manjarrez`} description={project.description} />
		<style>
			main {
				padding-top: 7rem;
				padding-bottom: 5rem;
			}
			.back-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				color: var(--text-secondary);
				text-decoration: none;
				transition: all var(--transition-fast);
				padding: var(--s-2);
				border-radius: 50%;
				background: var(--bg-surface);
				border: 1px solid var(--border-color);
				flex-shrink: 0;
			}
			.back-link:hover {
				color: var(--text-primary);
				border-color: var(--border-color-hover);
				background: var(--bg-surface-hover);
				transform: translateX(-4px);
			}
			.back-icon {
				width: 24px;
				height: 24px;
				display: block;
			}
			.project-header {
				margin-bottom: var(--s-8);
			}
			.project-title {
				font-size: clamp(2.2rem, 6vw, 3.5rem);
				font-weight: 850;
				line-height: 1.1;
				margin: 0 0 var(--s-3) 0;
				color: var(--text-primary);
				display: flex;
				align-items: center;
				gap: var(--s-4);
			}
			.project-tags {
				display: flex;
				gap: var(--s-2);
				flex-wrap: wrap;
			}
			.project-tags span {
				font-size: 0.75rem;
				padding: var(--s-1) var(--s-3);
				background: var(--bg-surface);
				border: 1px solid var(--border-color);
				color: var(--text-secondary);
				border-radius: 6px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.project-gallery {
				margin-bottom: var(--s-10);
				display: flex;
				flex-direction: column;
				gap: var(--s-4);
			}
			.gallery-main-wrapper {
				position: relative;
				width: 100%;
				height: 480px;
				border-radius: var(--radius-lg);
				overflow: hidden;
				border: 1px solid var(--border-color);
				box-shadow: var(--shadow-glow);
				background: var(--bg-surface);
			}
			@media (max-width: 768px) {
				.gallery-main-wrapper {
					height: 280px;
				}
			}
			.gallery-main-img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.gallery-fallback-gradient {
				width: 100%;
				height: 100%;
			}
			.gallery-thumbnails {
				display: flex;
				gap: var(--s-3);
				overflow-x: auto;
				padding-bottom: var(--s-2);
			}
			.gallery-thumb-btn {
				width: 100px;
				height: 65px;
				border-radius: var(--radius-sm);
				overflow: hidden;
				border: 2px solid var(--border-color);
				cursor: pointer;
				background: none;
				padding: 0;
				transition: border-color var(--transition-fast), transform var(--transition-fast);
				flex-shrink: 0;
			}
			.gallery-thumb-btn img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
			.gallery-thumb-btn:hover {
				border-color: var(--border-color-hover);
				transform: scale(1.03);
			}
			.gallery-thumb-btn.active {
				border-color: var(--accent-start);
				box-shadow: 0 0 10px var(--accent-glow);
			}
			.gallery-nav-btn {
				position: absolute;
				top: 50%;
				transform: translateY(-50%);
				width: 48px;
				height: 48px;
				border-radius: 50%;
				background: var(--bg-surface);
				border: 1px solid var(--border-color);
				color: var(--text-primary);
				display: flex;
				align-items: center;
				justify-content: center;
				cursor: pointer;
				z-index: 10;
				transition: border-color var(--transition-fast), color var(--transition-fast), transform var(--transition-fast), opacity var(--transition-fast);
				box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
				opacity: 0.7;
			}
			.gallery-nav-btn:hover {
				opacity: 1;
				border-color: var(--accent-start);
				color: var(--accent-start);
				transform: translateY(-50%) scale(1.08);
			}
			.gallery-nav-btn:active {
				transform: translateY(-50%) scale(0.95);
			}
			.gallery-nav-btn.prev {
				left: var(--s-4);
			}
			.gallery-nav-btn.next {
				right: var(--s-4);
			}
			.gallery-zoom-btn {
				position: absolute;
				bottom: 24px;
				left: 50%;
				transform: translateX(-50%) translateY(0);
				background: var(--bg-surface);
				backdrop-filter: blur(8px);
				-webkit-backdrop-filter: blur(8px);
				border: 1px solid var(--border-color);
				color: var(--text-primary);
				padding: 12px 26px;
				border-radius: 100px;
				font-size: 0.95rem;
				font-weight: 600;
				display: inline-flex;
				align-items: center;
				gap: 10px;
				cursor: pointer;
				z-index: 10;
				box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
				opacity: 0.85;
				transition: border-color var(--transition-fast), color var(--transition-fast), transform var(--transition-fast), background var(--transition-fast), box-shadow var(--transition-fast), opacity var(--transition-fast);
			}
			.gallery-zoom-btn:hover {
				opacity: 1;
				background: var(--bg-surface-hover);
				border-color: var(--accent-start);
				color: var(--accent-start);
				transform: translateX(-50%) translateY(-3px);
				box-shadow: 0 12px 30px rgba(0, 0, 0, 0.3);
			}
			.gallery-zoom-btn:active {
				transform: translateX(-50%) translateY(0px);
			}
			.lightbox-modal {
				position: fixed;
				inset: 0;
				background: rgba(0, 0, 0, 0.9);
				z-index: 1000;
				display: flex;
				align-items: center;
				justify-content: center;
				opacity: 0;
				pointer-events: none;
				transition: opacity 0.3s ease;
				backdrop-filter: blur(8px);
			}
			.lightbox-modal.active {
				opacity: 1;
				pointer-events: all;
			}
			.lightbox-content {
				max-width: 90vw;
				max-height: 85vh;
				position: relative;
				transform: scale(0.95);
				transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
			}
			.lightbox-modal.active .lightbox-content {
				transform: scale(1);
			}
			.lightbox-content img {
				max-width: 100%;
				max-height: 85vh;
				object-fit: contain;
				border-radius: var(--radius-md);
				border: 1px solid rgba(255, 255, 255, 0.1);
				box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
			}
			.lightbox-close {
				position: absolute;
				top: var(--s-6);
				right: var(--s-6);
				background: rgba(255, 255, 255, 0.1);
				border: 1px solid rgba(255, 255, 255, 0.2);
				color: #ffffff;
				width: 48px;
				height: 48px;
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				cursor: pointer;
				transition: background var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
			}
			.lightbox-close:hover {
				background: rgba(255, 255, 255, 0.25);
				border-color: #ffffff;
				transform: scale(1.08);
			}
			.lightbox-close:active {
				transform: scale(0.95);
			}
			.project-grid {
				display: grid;
				grid-template-columns: 2.2fr 1fr;
				gap: var(--s-10);
			}
			@media (max-width: 868px) {
				.project-grid {
					grid-template-columns: 1fr;
					gap: var(--s-8);
				}
			}
			.main-content {
				display: flex;
				flex-direction: column;
				height: 100%;
			}
			.main-content .details-card:last-child {
				margin-bottom: 0;
				flex-grow: 1;
			}
			.details-card {
				background: var(--bg-surface);
				border: 1px solid var(--border-color);
				border-radius: var(--radius-md);
				padding: var(--s-8);
				margin-bottom: var(--s-8);
			}
			.details-card h2 {
				font-size: 1.5rem;
				margin-top: 0;
				margin-bottom: var(--s-4);
				color: var(--text-primary);
				border-bottom: 1px solid var(--border-color);
				padding-bottom: var(--s-2);
			}
			.details-card p {
				color: var(--text-secondary);
				line-height: 1.7;
				margin-bottom: 0;
			}
			.features-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: var(--s-3);
			}
			.features-list li {
				display: flex;
				align-items: flex-start;
				gap: var(--s-3);
				color: var(--text-secondary);
				line-height: 1.5;
			}
			.feature-icon {
				color: var(--accent-start);
				flex-shrink: 0;
				margin-top: 2px;
			}
			.sidebar-sticky {
				position: sticky;
				top: 8rem;
				display: flex;
				flex-direction: column;
				gap: var(--s-6);
				align-self: start;
			}
			.info-box {
				background: var(--bg-surface);
				border: 1px solid var(--border-color);
				border-radius: var(--radius-md);
				padding: var(--s-6);
			}
			.info-box h3 {
				font-size: 1.15rem;
				margin-top: 0;
				margin-bottom: var(--s-3);
				color: var(--text-primary);
			}
			.info-list {
				display: flex;
				flex-direction: column;
				gap: var(--s-3);
				font-size: 0.9rem;
				color: var(--text-secondary);
			}
			.info-item {
				display: flex;
				justify-content: space-between;
				border-bottom: 1px dashed var(--border-color);
				padding-bottom: var(--s-2);
			}
			.info-item:last-child {
				border-bottom: none;
				padding-bottom: 0;
			}
			.info-item span:first-child {
				font-weight: 500;
				color: var(--text-muted);
			}
			.info-item span:last-child {
				font-weight: 600;
				color: var(--text-primary);
			}
			.action-buttons {
				display: flex;
				gap: var(--s-3);
				width: 100%;
			}
			.action-buttons .btn {
				flex: 1;
				white-space: nowrap;
			}
			.btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: var(--s-2);
				padding: var(--s-3) var(--s-4);
				border-radius: 8px;
				font-weight: 600;
				text-decoration: none;
				transition: all var(--transition-fast);
				font-size: 0.95rem;
				text-align: center;
				cursor: pointer;
			}
			.btn-primary {
				background: var(--accent-start);
				color: #ffffff;
				box-shadow: 0 4px 14px var(--accent-glow);
				border: none;
			}
			.btn-primary:hover {
				background: var(--accent-end);
				transform: translateY(-2px);
				box-shadow: 0 6px 20px var(--accent-glow);
			}
			.btn-secondary {
				background: transparent;
				color: var(--text-primary);
				border: 1px solid var(--border-color);
			}
			.btn-secondary:hover {
				background: var(--bg-surface-hover);
				border-color: var(--border-color-hover);
				transform: translateY(-2px);
			}
		</style>
	</head>
	<body>
		<BackgroundVectors />
		<Header />
		<main class="container">
			<header class="project-header">
				<h1 class="project-title">
					<a href="/" class="back-link" aria-label="Volver al inicio">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="back-icon"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
					</a>
					<span>{project.title}</span>
				</h1>
				<div class="project-tags">
					{project.tags.map((tag) => (
						<span>{tag}</span>
					))}
				</div>
			</header>

			<div class="project-gallery">
				<div class="gallery-main-wrapper">
					{project.image ? (
						<img 
							id="gallery-main-img"
							src={project.image} 
							alt={project.title}
							class="gallery-main-img" 
							style={`view-transition-name: project-banner-${project.slug};`}
						/>
					) : (
						<div 
							class="gallery-fallback-gradient" 
							style={`background: ${project.gradient}; view-transition-name: project-banner-${project.slug};`}
						/>
					)}

					{project.gallery && project.gallery.length > 1 && (
						<>
							<button id="gallery-prev-btn" class="gallery-nav-btn prev" aria-label="Imagen anterior">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
							</button>
							<button id="gallery-next-btn" class="gallery-nav-btn next" aria-label="Siguiente imagen">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
							</button>
						</>
					)}

					{project.image && (
						<button id="gallery-zoom-btn" class="gallery-zoom-btn" aria-label="Ver imagen completa">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="zoom-icon"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
							<span>Ampliar imagen</span>
						</button>
					)}
				</div>
				
				{project.gallery && project.gallery.length > 1 && (
					<div class="gallery-thumbnails">
						{project.gallery.map((imgUrl, index) => (
							<button 
								class={`gallery-thumb-btn ${index === 0 ? 'active' : ''}`}
								data-src={imgUrl}
								aria-label={`Ver imagen ${index + 1}`}
							>
								<img src={imgUrl} alt={`${project.title} - Captura ${index + 1}`} />
							</button>
						))}
					</div>
				)}
			</div>

			<div class="project-grid">
				<div class="main-content">
					<div class="details-card">
						<h2>Sobre el proyecto</h2>
						<p>{project.longDescription}</p>
					</div>

					<div class="details-card">
						<h2>Características principales</h2>
						<ul class="features-list">
							{project.features.map((feature) => (
								<li>
									<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="feature-icon"><polyline points="20 6 9 17 4 12"/></svg>
									<span>{feature}</span>
								</li>
							))}
						</ul>
					</div>
				</div>

				<div class="sidebar-sticky">
					<div class="info-box">
						<h3>Detalles técnicos</h3>
						<div class="info-list">
							<div class="info-item">
								<span>Estado</span>
								<span>Completado</span>
							</div>
							<div class="info-item">
								<span>Rol</span>
								<span>Developer Principal</span>
							</div>
							<div class="info-item">
								<span>Arquitectura</span>
								<span>Jamstack / SSG</span>
							</div>
						</div>
					</div>

					<div class="action-buttons">
						<a href="#" class="btn btn-primary">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
							Demo en vivo
						</a>
						<a href="#" class="btn btn-secondary">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
							Código fuente
						</a>
					</div>
				</div>
			</div>
		</main>
		<Footer />

		<!-- Lightbox Modal -->
		<div id="lightbox-modal" class="lightbox-modal" aria-hidden="true" role="dialog">
			<button class="lightbox-close" aria-label="Cerrar modal">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
			</button>
			<div class="lightbox-content">
				<img id="lightbox-img" src="" alt="Vista ampliada" />
			</div>
		</div>

		<script>
			function setupGallery() {
				const mainImg = document.getElementById('gallery-main-img') as HTMLImageElement | null;
				const thumbnails = document.querySelectorAll('.gallery-thumb-btn');
				const prevBtn = document.getElementById('gallery-prev-btn');
				const nextBtn = document.getElementById('gallery-next-btn');

				const zoomBtn = document.getElementById('gallery-zoom-btn');
				const lightbox = document.getElementById('lightbox-modal');
				const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
				const lightboxClose = document.querySelector('.lightbox-close');

				if (zoomBtn && lightbox && lightboxImg) {
					zoomBtn.addEventListener('click', () => {
						if (mainImg) {
							lightboxImg.src = mainImg.src;
							lightbox.classList.add('active');
							document.body.style.overflow = 'hidden';
						}
					});

					const closeLightbox = () => {
						lightbox.classList.remove('active');
						document.body.style.overflow = '';
					};

					if (lightboxClose) {
						lightboxClose.addEventListener('click', closeLightbox);
					}

					lightbox.addEventListener('click', (e) => {
						if (e.target === lightbox) {
							closeLightbox();
						}
					});

					const handleKeyDown = (e: KeyboardEvent) => {
						if (e.key === 'Escape') {
							closeLightbox();
						}
					};
					document.addEventListener('keydown', handleKeyDown);
					
					document.addEventListener('astro:before-swap', () => {
						document.removeEventListener('keydown', handleKeyDown);
						document.body.style.overflow = '';
					}, { once: true });
				}

				if (!mainImg || thumbnails.length === 0) return;

				const sources = Array.from(thumbnails).map(btn => btn.getAttribute('data-src') || '');

				let currentIndex = sources.indexOf(mainImg.getAttribute('src') || '');
				if (currentIndex === -1) currentIndex = 0;

				function updateGalleryImage(index: number) {
					if (index < 0 || index >= sources.length) return;
					currentIndex = index;
					const newSrc = sources[currentIndex];
					
					mainImg!.src = newSrc;

					thumbnails.forEach((t, i) => {
						if (i === currentIndex) {
							t.classList.add('active');
							t.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
						} else {
							t.classList.remove('active');
						}
					});
				}

				thumbnails.forEach((btn, index) => {
					btn.addEventListener('click', () => {
						updateGalleryImage(index);
					});
				});

				if (prevBtn) {
					prevBtn.addEventListener('click', () => {
						let newIndex = currentIndex - 1;
						if (newIndex < 0) newIndex = sources.length - 1;
						updateGalleryImage(newIndex);
					});
				}

				if (nextBtn) {
					nextBtn.addEventListener('click', () => {
						let newIndex = currentIndex + 1;
						if (newIndex >= sources.length) newIndex = 0;
						updateGalleryImage(newIndex);
					});
				}
			}

			// Run on initial load and after transition swap
			setupGallery();
			document.addEventListener('astro:page-load', setupGallery);
		</script>
	</body>
</html>
