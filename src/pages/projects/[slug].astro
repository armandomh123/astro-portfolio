---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BackgroundVectors from '../../components/BackgroundVectors.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`${project.data.title} - Jesús Manjarrez`} description={project.data.description} />
		<style>
			main {
				padding-top: 7rem;
				padding-bottom: 5rem;
			}
			.back-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				color: var(--text-secondary);
				text-decoration: none;
				transition: all var(--transition-fast);
				padding: var(--s-2);
				border-radius: 50%;
				background: var(--bg-surface);
				border: 1px solid var(--border-color);
				flex-shrink: 0;
			}
			.back-link:hover {
				color: var(--text-primary);
				border-color: var(--border-color-hover);
				background: var(--bg-surface-hover);
				transform: translateX(-4px);
			}
			.back-icon {
				width: 24px;
				height: 24px;
				display: block;
			}
			.project-header {
				margin-bottom: var(--s-8);
			}
			.project-title {
				font-size: clamp(2.2rem, 6vw, 3.5rem);
				font-weight: 850;
				line-height: 1.1;
				margin: 0 0 var(--s-3) 0;
				color: var(--text-primary);
				display: flex;
				align-items: center;
				gap: var(--s-4);
			}
			.project-tags {
				display: flex;
				gap: var(--s-2);
				flex-wrap: wrap;
			}
			.project-tags span {
				font-size: 0.75rem;
				padding: var(--s-1) var(--s-3);
				background: var(--bg-surface);
				border: 1px solid var(--border-color);
				color: var(--text-secondary);
				border-radius: 6px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.project-gallery {
				margin-bottom: var(--s-10);
				display: flex;
				flex-direction: column;
				gap: var(--s-4);
			}
			.gallery-main-wrapper {
				position: relative;
				width: 100%;
				height: 480px;
				border-radius: var(--radius-lg);
				overflow: hidden;
				border: 1px solid var(--border-color);
				box-shadow: var(--shadow-glow);
				background: var(--bg-surface);
			}
			@media (max-width: 768px) {
				.gallery-main-wrapper {
					height: 280px;
				}
			}
			.gallery-main-img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.gallery-fallback-gradient {
				width: 100%;
				height: 100%;
			}
			.gallery-thumbnails {
				display: flex;
				gap: var(--s-3);
				overflow-x: auto;
				padding-bottom: var(--s-2);
			}
			.gallery-thumb-btn {
				width: 100px;
				height: 65px;
				border-radius: var(--radius-sm);
				overflow: hidden;
				border: none;
				cursor: pointer;
				background: var(--bg-surface);
				padding: 0;
				transition: box-shadow var(--transition-fast), transform var(--transition-fast);
				flex-shrink: 0;
				box-shadow: inset 0 0 0 2px var(--border-color);
			}
			.gallery-thumb-btn img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: var(--radius-sm);
				display: block;
			}
			.gallery-thumb-btn:hover {
				box-shadow: inset 0 0 0 2px var(--border-color-hover);
				transform: scale(1.03);
			}
			.gallery-thumb-btn.active {
				box-shadow: inset 0 0 0 2px var(--accent-start), 0 0 10px var(--accent-glow);
			}
			.gallery-nav-btn {
				position: absolute;
				top: 50%;
				transform: translateY(-50%);
				width: 48px;
				height: 48px;
				border-radius: 50%;
				background: var(--bg-surface);
				border: 1px solid var(--border-color);
				color: var(--text-primary);
				display: flex;
				align-items: center;
				justify-content: center;
				cursor: pointer;
				z-index: 10;
				transition: border-color var(--transition-fast), color var(--transition-fast), transform var(--transition-fast), opacity var(--transition-fast);
				box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
				opacity: 0.7;
			}
			.gallery-nav-btn:hover {
				opacity: 1;
				border-color: var(--accent-start);
				color: var(--accent-start);
				transform: translateY(-50%) scale(1.08);
			}
			.gallery-nav-btn:active {
				transform: translateY(-50%) scale(0.95);
			}
			.gallery-nav-btn.prev {
				left: var(--s-4);
			}
			.gallery-nav-btn.next {
				right: var(--s-4);
			}
			.gallery-zoom-btn {
				position: absolute;
				bottom: 24px;
				left: 50%;
				transform: translateX(-50%) translateY(0);
				background: var(--bg-surface);
				backdrop-filter: blur(8px);
				-webkit-backdrop-filter: blur(8px);
				border: 1px solid var(--border-color);
				color: var(--text-primary);
				padding: 12px 26px;
				border-radius: 100px;
				font-size: 0.95rem;
				font-weight: 600;
				display: inline-flex;
				align-items: center;
				gap: 10px;
				cursor: pointer;
				z-index: 10;
				box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
				opacity: 0.85;
				transition: border-color var(--transition-fast), color var(--transition-fast), transform var(--transition-fast), background var(--transition-fast), box-shadow var(--transition-fast), opacity var(--transition-fast);
			}
			.gallery-zoom-btn:hover {
				opacity: 1;
				background: var(--bg-surface-hover);
				border-color: var(--accent-start);
				color: var(--accent-start);
				transform: translateX(-50%) translateY(-3px);
				box-shadow: 0 12px 30px rgba(0, 0, 0, 0.3);
			}
			.gallery-zoom-btn:active {
				transform: translateX(-50%) translateY(0px);
			}
			.lightbox-modal {
				position: fixed;
				inset: 0;
				background: rgba(0, 0, 0, 0.9);
				z-index: 1000;
				display: flex;
				align-items: center;
				justify-content: center;
				opacity: 0;
				pointer-events: none;
				transition: opacity 0.3s ease;
				backdrop-filter: blur(8px);
			}
			.lightbox-modal.active {
				opacity: 1;
				pointer-events: all;
			}
			.lightbox-content {
				max-width: 90vw;
				max-height: 85vh;
				position: relative;
				transform: scale(0.95);
				transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
			}
			.lightbox-modal.active .lightbox-content {
				transform: scale(1);
			}
			.lightbox-content img {
				max-width: 100%;
				max-height: 85vh;
				object-fit: contain;
				border-radius: var(--radius-md);
				border: 1px solid rgba(255, 255, 255, 0.1);
				box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
			}
			.lightbox-close {
				position: absolute;
				top: var(--s-6);
				right: var(--s-6);
				background: rgba(255, 255, 255, 0.1);
				border: 1px solid rgba(255, 255, 255, 0.2);
				color: #ffffff;
				width: 48px;
				height: 48px;
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				cursor: pointer;
				transition: background var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
			}
			.lightbox-close:hover {
				background: rgba(255, 255, 255, 0.25);
				border-color: #ffffff;
				transform: scale(1.08);
			}
			.lightbox-close:active {
				transform: scale(0.95);
			}
			.project-details-wrapper {
				max-width: 800px;
				margin: 0 auto;
			}
			.project-details-layout {
				width: 100%;
			}
			.project-section h2 {
				font-size: 1.4rem;
				font-weight: 750;
				margin-top: 0;
				margin-bottom: var(--s-4);
				color: var(--text-primary);
				border-left: 3px solid var(--accent-start);
				padding-left: var(--s-3);
			}
			.project-content {
				color: var(--text-secondary);
				line-height: 1.8;
				font-size: 1.05rem;
			}
			.project-content :global(p) {
				max-width: none;
				margin-bottom: var(--s-6);
			}
			.project-content :global(strong) {
				color: var(--text-primary);
				font-weight: 600;
			}
			.project-content :global(h3) {
				font-size: 1.4rem;
				font-weight: 750;
				margin-top: var(--s-10);
				margin-bottom: var(--s-4);
				color: var(--text-primary);
				border-left: 3px solid var(--accent-start);
				padding-left: var(--s-3);
			}
			.project-content :global(ol) {
				list-style: none;
				counter-reset: project-counter;
				padding-left: 0;
				display: flex;
				flex-direction: column;
				gap: var(--s-4);
				margin: var(--s-6) 0;
			}
			.project-content :global(ol > li) {
				counter-increment: project-counter;
				position: relative;
				padding-left: var(--s-10);
				color: var(--text-secondary);
			}
			.project-content :global(ol > li::before) {
				content: counter(project-counter);
				position: absolute;
				left: 0;
				top: 0.15rem;
				width: 1.75rem;
				height: 1.75rem;
				background: var(--bg-surface);
				border: 1px solid var(--border-color);
				border-radius: 50%;
				color: var(--accent-start);
				font-weight: 700;
				font-size: 0.85rem;
				display: flex;
				align-items: center;
				justify-content: center;
				box-shadow: var(--shadow-glow);
			}
			.project-content :global(ul) {
				list-style: none;
				padding-left: 0;
				display: flex;
				flex-direction: column;
				gap: var(--s-3);
				margin: var(--s-6) 0;
			}
			.project-content :global(ul > li) {
				position: relative;
				padding-left: var(--s-6);
				color: var(--text-secondary);
			}
			.project-content :global(ul > li::before) {
				content: "•";
				position: absolute;
				left: var(--s-1);
				top: -0.1rem;
				color: var(--accent-start);
				font-size: 1.4rem;
				font-weight: 700;
			}
			.project-content :global(code) {
				background: var(--bg-surface);
				border: 1px solid var(--border-color);
				padding: 0.15rem 0.35rem;
				border-radius: var(--radius-sm);
				color: var(--accent-start);
				font-size: 0.9em;
				font-family: inherit;
			}

		</style>
	</head>
	<body>
		<BackgroundVectors />
		<Header />
		<main class="container">
			<div class="project-details-wrapper">
				<header class="project-header">
					<h1 class="project-title">
						<a href="/" class="back-link" aria-label="Volver al inicio">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="back-icon"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
						</a>
						<span>{project.data.title}</span>
					</h1>
					<div class="project-tags">
						{project.data.tags.map((tag) => (
							<span>{tag}</span>
						))}
					</div>
				</header>

				<div class="project-gallery">
					<div class="gallery-main-wrapper">
						{project.data.image ? (
							<img 
								id="gallery-main-img"
								src={project.data.image} 
								alt={project.data.title}
								class="gallery-main-img" 
								style={`view-transition-name: project-banner-${project.id};`}
							/>
						) : (
							<div 
								class="gallery-fallback-gradient" 
								style={`background: ${project.data.gradient}; view-transition-name: project-banner-${project.id};`}
							/>
						)}

						{project.data.gallery && project.data.gallery.length > 1 && (
							<>
								<button id="gallery-prev-btn" class="gallery-nav-btn prev" aria-label="Imagen anterior">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
								</button>
								<button id="gallery-next-btn" class="gallery-nav-btn next" aria-label="Siguiente imagen">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
								</button>
							</>
						)}

						{project.data.image && (
							<button id="gallery-zoom-btn" class="gallery-zoom-btn" aria-label="Ver imagen completa">
								<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="zoom-icon"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
								<span>Ampliar imagen</span>
							</button>
						)}
					</div>
					
					{project.data.gallery && project.data.gallery.length > 1 && (
						<div class="gallery-thumbnails">
							{project.data.gallery.map((imgUrl, index) => (
								<button 
									class={`gallery-thumb-btn ${index === 0 ? 'active' : ''}`}
									data-src={imgUrl}
									aria-label={`Ver imagen ${index + 1}`}
								>
									<img src={imgUrl} alt={`${project.data.title} - Captura ${index + 1}`} />
								</button>
							))}
						</div>
					)}
				</div>

				<div class="project-details-layout">
					<section class="project-section">
						<h2>Sobre el proyecto</h2>
						<div class="project-content">
							<Content />
						</div>
					</section>
				</div>
			</div>
		</main>
		<Footer />

		<!-- Lightbox Modal -->
		<div id="lightbox-modal" class="lightbox-modal" aria-hidden="true" role="dialog">
			<button class="lightbox-close" aria-label="Cerrar modal">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
			</button>
			<div class="lightbox-content">
				<img id="lightbox-img" src="" alt="Vista ampliada" />
			</div>
		</div>

		<script>
			function setupGallery() {
				const mainImg = document.getElementById('gallery-main-img') as HTMLImageElement | null;
				const thumbnails = document.querySelectorAll('.gallery-thumb-btn');
				const prevBtn = document.getElementById('gallery-prev-btn');
				const nextBtn = document.getElementById('gallery-next-btn');

				const zoomBtn = document.getElementById('gallery-zoom-btn');
				const lightbox = document.getElementById('lightbox-modal');
				const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
				const lightboxClose = document.querySelector('.lightbox-close');

				if (zoomBtn && lightbox && lightboxImg) {
					zoomBtn.addEventListener('click', () => {
						if (mainImg) {
							lightboxImg.src = mainImg.src;
							lightbox.classList.add('active');
							document.body.style.overflow = 'hidden';
						}
					});

					const closeLightbox = () => {
						lightbox.classList.remove('active');
						document.body.style.overflow = '';
					};

					if (lightboxClose) {
						lightboxClose.addEventListener('click', closeLightbox);
					}

					lightbox.addEventListener('click', (e) => {
						if (e.target === lightbox) {
							closeLightbox();
						}
					});

					const handleKeyDown = (e: KeyboardEvent) => {
						if (e.key === 'Escape') {
							closeLightbox();
						}
					};
					document.addEventListener('keydown', handleKeyDown);
					
					document.addEventListener('astro:before-swap', () => {
						document.removeEventListener('keydown', handleKeyDown);
						document.body.style.overflow = '';
					}, { once: true });
				}

				if (!mainImg || thumbnails.length === 0) return;

				const sources = Array.from(thumbnails).map(btn => btn.getAttribute('data-src') || '');

				let currentIndex = sources.indexOf(mainImg.getAttribute('src') || '');
				if (currentIndex === -1) currentIndex = 0;

				function updateGalleryImage(index: number) {
					if (index < 0 || index >= sources.length) return;
					currentIndex = index;
					const newSrc = sources[currentIndex];
					
					mainImg!.src = newSrc;

					thumbnails.forEach((t, i) => {
						if (i === currentIndex) {
							t.classList.add('active');
							t.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
						} else {
							t.classList.remove('active');
						}
					});
				}

				thumbnails.forEach((btn, index) => {
					btn.addEventListener('click', () => {
						updateGalleryImage(index);
					});
				});

				if (prevBtn) {
					prevBtn.addEventListener('click', () => {
						let newIndex = currentIndex - 1;
						if (newIndex < 0) newIndex = sources.length - 1;
						updateGalleryImage(newIndex);
					});
				}

				if (nextBtn) {
					nextBtn.addEventListener('click', () => {
						let newIndex = currentIndex + 1;
						if (newIndex >= sources.length) newIndex = 0;
						updateGalleryImage(newIndex);
					});
				}
			}

			// Run on initial load and after transition swap
			setupGallery();
			document.addEventListener('astro:page-load', setupGallery);
		</script>
	</body>
</html>
