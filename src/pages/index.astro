---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION, PROJECTS, SKILLS, NAME } from "../consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		
		<main>
			<!-- Hero Section -->
			<section id="hero" class="section container">
				<div class="reveal">
					<span class="section-label">Bienvenido</span>
					<h1>Hola, soy <span class="gradient-text">{NAME}</span></h1>
					<p class="hero-description">
						Desarrollador Full Stack enfocado en crear productos digitales 
						con interfaces intuitivas y código escalable.
					</p>
					<div class="hero-actions">
						<a href="#projects" class="btn btn-primary">Ver proyectos</a>
						<a href="#contact" class="btn btn-secondary">Contactar</a>
					</div>
				</div>
			</section>

			<!-- About Section -->
			<section id="about" class="section container">
				<div class="reveal">
					<span class="section-label">Sobre mí</span>
					<h2 class="section-title">Pasión por la tecnología</h2>
					<div class="about-grid">
						<div class="about-text">
							<p>
								Llevo años explorando el ecosistema web, desde el diseño de UI 
								hasta la arquitectura de bases de datos. Me apasiona resolver 
								problemas complejos mediante soluciones simples y elegantes.
							</p>
							<p>
								Mi enfoque se centra en el rendimiento, la accesibilidad y la 
								experiencia del usuario final.
							</p>
						</div>
						<div class="about-skills">
							<h3>Skills</h3>
							<div class="skill-tags">
								{SKILLS.map(skill => <span class="skill-tag">{skill}</span>)}
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Projects Section -->
			<section id="projects" class="section container">
				<div class="reveal">
					<span class="section-label">Proyectos</span>
					<h2 class="section-title">Trabajo reciente</h2>
					<p class="section-subtitle">Una selección de proyectos en los que he trabajado últimamente.</p>
					
					<div class="projects-grid">
						{PROJECTS.map(project => (
							<div class="project-card glass-card">
								<div class="project-image" style={`background: ${project.gradient}`}></div>
								<div class="project-content">
									<h3>{project.title}</h3>
									<p>{project.description}</p>
									<div class="project-tags">
										{project.tags.map(tag => <span>{tag}</span>)}
									</div>
									<a href={project.link} class="project-link">Ver más →</a>
								</div>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- Contact Section -->
			<section id="contact" class="section container">
				<div class="reveal">
					<span class="section-label">Contacto</span>
					<h2 class="section-title">¿Tienes un proyecto en mente?</h2>
					<p class="section-subtitle">Estoy disponible para nuevos proyectos o colaboraciones.</p>
					
					<div class="contact-card glass-card">
						<h3>Hablemos</h3>
						<p>No dudes en enviarme un mensaje si quieres charlar sobre tecnología o nuevas oportunidades.</p>
						<a href="mailto:contacto@example.com" class="btn btn-primary">Enviar Email</a>
					</div>
				</div>
			</section>
		</main>

		<Footer />

		<script>
			// Scroll Reveal Animation
			const observerOptions = {
				threshold: 0.1,
				rootMargin: "0px 0px -50px 0px"
			};

			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible');
					}
				});
			}, observerOptions);

			document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
		</script>

		<style>
			main {
				margin-top: 5rem;
			}
			.hero-description {
				font-size: 1.25rem;
				max-width: 600px;
				margin-bottom: 2.5rem;
			}
			.hero-actions {
				display: flex;
				gap: 1rem;
			}
			
			/* Buttons */
			.btn {
				display: inline-flex;
				align-items: center;
				padding: 0.8rem 1.8rem;
				border-radius: var(--radius-md);
				font-weight: 600;
				transition: all var(--transition-base);
				cursor: pointer;
			}
			.btn-primary {
				background: var(--accent-gradient);
				color: white;
				box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);
			}
			.btn-primary:hover {
				transform: translateY(-2px);
				box-shadow: 0 8px 25px rgba(139, 92, 246, 0.4);
				color: white;
			}
			.btn-secondary {
				background: var(--bg-surface);
				border: 1px solid var(--border-color);
				color: var(--text-primary);
			}
			.btn-secondary:hover {
				background: var(--bg-surface-hover);
				border-color: var(--border-color-hover);
			}

			/* About */
			.about-grid {
				display: grid;
				grid-template-columns: 1.5fr 1fr;
				gap: 4rem;
				margin-top: 2rem;
			}
			.skill-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				margin-top: 1rem;
			}
			.skill-tag {
				padding: 0.4rem 1rem;
				background: var(--bg-surface);
				border: 1px solid var(--border-color);
				border-radius: 100px;
				font-size: 0.9rem;
				color: var(--text-secondary);
			}

			/* Projects */
			.projects-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
				gap: 2rem;
				margin-top: 3rem;
			}
			.project-card {
				overflow: hidden;
				display: flex;
				flex-direction: column;
			}
			.project-image {
				height: 200px;
				width: 100%;
				opacity: 0.8;
				transition: opacity var(--transition-base);
			}
			.project-card:hover .project-image {
				opacity: 1;
			}
			.project-content {
				padding: 1.5rem;
				display: flex;
				flex-direction: column;
				flex-grow: 1;
			}
			.project-content h3 {
				margin-bottom: 0.75rem;
			}
			.project-tags {
				display: flex;
				gap: 0.5rem;
				margin: 1rem 0 1.5rem;
				flex-wrap: wrap;
			}
			.project-tags span {
				font-size: 0.75rem;
				padding: 0.2rem 0.6rem;
				background: var(--bg-elevated);
				color: var(--accent-start);
				border-radius: 4px;
				font-weight: 600;
			}
			.project-link {
				margin-top: auto;
				font-weight: 600;
				font-size: 0.9rem;
			}

			/* Contact */
			.contact-card {
				margin-top: 3rem;
				padding: 3rem;
				text-align: center;
				max-width: 700px;
				margin-left: auto;
				margin-right: auto;
			}
			.contact-card h3 {
				font-size: 2rem;
				margin-bottom: 1rem;
			}
			.contact-card p {
				margin-bottom: 2rem;
			}

			@media (max-width: 768px) {
				.about-grid {
					grid-template-columns: 1fr;
					gap: 2rem;
				}
				.contact-card {
					padding: 2rem;
				}
			}
		</style>
	</body>
</html>
