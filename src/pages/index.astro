---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BackgroundVectors from "../components/BackgroundVectors.astro";
import SkillIcon from "../components/SkillIcon.astro";
import {
	SITE_TITLE,
	SITE_DESCRIPTION,
	SKILLS,
	NAME,
	SOCIAL_LINKS,
} from "../consts";

const projectsOrder = [
	"sitehasa-web",
	"sitehasa-movil",
	"astro-portfolio",
];

const projects = (await getCollection("projects")).sort(
	(a, b) => projectsOrder.indexOf(a.id) - projectsOrder.indexOf(b.id),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<BackgroundVectors />
		<Header />
		?
		<main>
			<!-- Hero Section -->
			<section id="hero" class="section container">
				<div class="reveal">
					<h1>Hola, soy <span class="gradient-text">{NAME}</span></h1>
					<p class="hero-description">
						Ingeniero en Desarrollo y Gestión de software
					</p>
					<div class="hero-actions">
						<a href="#projects" class="btn btn-primary"
							>Ver proyectos</a
						>
						<a href="#contact" class="btn btn-secondary"
							>Contactar</a
						>
					</div>
				</div>
				<a
					href="#about"
					class="scroll-indicator"
					aria-label="Desplazarse hacia abajo"
				>
					<div class="mouse">
						<div class="wheel"></div>
					</div>
					<div class="arrow">
						<span></span>
						<span></span>
					</div>
				</a>
			</section>

			<!-- About Section -->
			<section id="about" class="section container">
				<div class="reveal">
					<div class="about-grid">
						<div class="about-text">
							<h2 class="section-title">Sobre mí</h2>
							<p>
								Llevo años explorando el ecosistema web, desde
								el diseño de UI hasta la arquitectura de bases
								de datos. Me apasiona resolver problemas
								complejos mediante soluciones simples y
								elegantes.
							</p>
							<p>
								Mi enfoque se centra en el rendimiento, la
								accesibilidad y la experiencia del usuario
								final.
							</p>
						</div>
						<div class="about-skills">
							<h3 class="section-title">Skills</h3>
							<div class="skill-tags">
								{
									SKILLS.map((skill) => (
										<span class="skill-tag">
											<SkillIcon
												name={skill}
												size={18}
												class="skill-icon"
											/>
											{skill}
										</span>
									))
								}
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Projects Section -->
			<section id="projects" class="section container">
				<div class="reveal">
					<h2 class="section-title">Trabajo reciente</h2>
					<p class="section-subtitle">
						Una selección de proyectos en los que he trabajado.
					</p>

					<div class="projects-grid">
						{
							projects.map((project) => (
								<a
									href={`/projects/${project.id}`}
									class="project-card surface-card"
								>
									<div
										class="project-image"
										style={`background: ${project.data.image ? `url(${project.data.image}) center/cover no-repeat` : project.data.gradient}; view-transition-name: project-banner-${project.id};`}
									/>
									<div class="project-content">
										<h3>{project.data.title}</h3>
										<p>{project.data.description}</p>
										<div class="project-tags">
											{project.data.tags.map((tag) => (
												<span>{tag}</span>
											))}
										</div>
										<span class="project-link">
											Ver detalles
											<svg
												xmlns="http://www.w3.org/2000/svg"
												width="16"
												height="16"
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2.5"
												stroke-linecap="round"
												stroke-linejoin="round"
												class="link-icon"
											>
												<>
													<line
														x1="5"
														y1="12"
														x2="19"
														y2="12"
													/>
													<polyline points="12 5 19 12 12 19" />
												</>
											</svg>
										</span>
									</div>
								</a>
							))
						}
					</div>
				</div>
			</section>

			<!-- Experience Section -->
			<section id="experience" class="section container">
				<div class="reveal">
					<h2 class="section-title">Experiencia</h2>
					<p class="section-subtitle">
						Mi trayectoria y aportes en el ámbito profesional y tecnológico.
					</p>

					<div class="experience-timeline">
						<div class="timeline-item">
							<div class="timeline-badge"></div>
							<div class="timeline-content surface-card">
								<div class="experience-header">
									<div class="title-group">
										<h3>SITEHASA</h3>
										<span class="role">Estadías profesionales</span>
									</div>
									<span class="duration">Enero 2026 - Abril 2026</span>
								</div>
								<p class="experience-desc">
									Desarrollé y automaticé la operación de una garza de agua a través de un ecosistema móvil y web integrado con controladores de hardware.
								</p>
								<div class="experience-tags">
									<span>React Native</span>
									<span>Expo</span>
									<span>PHP</span>
									<span>Laravel</span>
									<span>Livewire</span>
									<span>Filament PHP</span>
									<span>MySQL</span>
									<span>Git</span>
								</div>
							</div>
						</div>

						<div class="timeline-item">
							<div class="timeline-badge"></div>
							<div class="timeline-content surface-card">
								<div class="experience-header">
									<div class="title-group">
										<h3>Alfanetworks</h3>
										<span class="role">Estadías profesionales</span>
									</div>
									<span class="duration">Abril 2024 - Agosto 2024</span>
								</div>
								<p class="experience-desc">
									Desarrollé una aplicación web para la gestión de eventos sociales (bautizos, bodas, fiestas, etc.) con roles diferenciados: administrador, planner e invitado.
								</p>
								<div class="experience-tags">
									<span>PHP</span>
									<span>JavaScript</span>
									<span>HTML</span>
									<span>CSS</span>
									<span>MySQL</span>
									<span>Figma</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Contact Section -->
			<section id="contact" class="section container">
				<div class="reveal">
					<h2 class="section-title">¿Tienes un proyecto en mente?</h2>
					<p class="section-subtitle">
						Estoy disponible para nuevos proyectos o colaboraciones.
					</p>

					<div class="contact-card surface-card">
						<div class="contact-card-content">
							<h3>Hablemos</h3>
							<p>
								No dudes en enviarme un mensaje si quieres charlar
								sobre tecnología o nuevas oportunidades.
							</p>
						</div>
						<a href={SOCIAL_LINKS.email} class="btn btn-primary"
							>Enviar Email</a
						>
					</div>
				</div>
			</section>
		</main>

		<Footer />

		<script>
			// Scroll Reveal Animation
			document.addEventListener("astro:page-load", () => {
				const observerOptions = {
					threshold: 0.1,
					rootMargin: "0px 0px -50px 0px",
				};

				const observer = new IntersectionObserver((entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add("visible");
						}
					});
				}, observerOptions);

				document
					.querySelectorAll(".reveal")
					.forEach((el) => observer.observe(el));

				// Clean up observer on page swap to avoid memory leaks
				document.addEventListener(
					"astro:before-swap",
					() => {
						observer.disconnect();
					},
					{ once: true },
				);
			});
		</script>

		<style>
			main {
				margin-top: var(--s-16);
			}
			#hero {
				min-height: calc(100vh - var(--s-16));
				display: flex;
				align-items: center;
				justify-content: center;
				padding-top: 0;
				padding-bottom: 0;
				position: relative;
			}
			#hero .reveal {
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
			}
			.hero-description {
				font-size: clamp(1rem, 4vw, 1.25rem);
				max-width: 600px;
				margin-bottom: var(--s-8);
				color: var(--text-secondary);
				line-height: 1.6;
				text-align: center;
			}
			.hero-actions {
				display: flex;
				gap: var(--s-4);
				flex-wrap: wrap;
				justify-content: center;
			}

			/* Scroll Indicator */
			.scroll-indicator {
				position: absolute;
				bottom: var(--s-8);
				left: 50%;
				transform: translateX(-50%);
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: var(--s-2);
				text-decoration: none;
				color: var(--text-muted);
				transition:
					color var(--transition-fast),
					opacity var(--transition-base);
				opacity: 0.6;
				z-index: 10;
			}
			.scroll-indicator:hover {
				color: var(--accent-start);
				opacity: 1;
			}
			.mouse {
				width: 22px;
				height: 36px;
				border: 2px solid currentColor;
				border-radius: 12px;
				position: relative;
			}
			.wheel {
				width: 4px;
				height: 8px;
				background-color: currentColor;
				border-radius: 2px;
				position: absolute;
				top: 6px;
				left: 50%;
				transform: translateX(-50%);
				animation: scroll-wheel 1.6s ease-out infinite;
			}
			.arrow {
				display: flex;
				flex-direction: column;
				align-items: center;
			}
			.arrow span {
				display: block;
				width: 8px;
				height: 8px;
				border-right: 2px solid currentColor;
				border-bottom: 2px solid currentColor;
				transform: rotate(45deg);
				margin: -2px;
				animation: arrow-bounce 1.6s infinite;
			}
			.arrow span:nth-child(2) {
				animation-delay: 0.2s;
			}

			@keyframes scroll-wheel {
				0% {
					opacity: 1;
					transform: translateX(-50%) translateY(0);
				}
				100% {
					opacity: 0;
					transform: translateX(-50%) translateY(14px);
				}
			}
			@keyframes arrow-bounce {
				0% {
					opacity: 0;
					transform: rotate(45deg) translate(-4px, -4px);
				}
				50% {
					opacity: 0.8;
				}
				100% {
					opacity: 0;
					transform: rotate(45deg) translate(4px, 4px);
				}
			}

			/* Buttons */
			.btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: var(--s-3) var(--s-8);
				border-radius: var(--radius-md);
				font-weight: 600;
				transition:
					transform var(--transition-base),
					background-color var(--transition-base),
					border-color var(--transition-base),
					box-shadow var(--transition-base);
				cursor: pointer;
				text-decoration: none;
				min-width: 160px;
			}
			.btn-primary {
				background: var(--accent-gradient);
				color: white;
				box-shadow: 0 1px 2px oklch(0.12 0.01 250 / 0.18);
			}
			.btn-primary:hover {
				transform: translateY(-1px);
				box-shadow: 0 6px 16px oklch(0.12 0.01 250 / 0.2);
				color: white;
			}
			.btn-secondary {
				background: var(--bg-surface);
				border: 1px solid var(--border-color);
				color: var(--text-primary);
			}
			.btn-secondary:hover {
				background: var(--bg-surface-hover);
				border-color: var(--border-color-hover);
				transform: translateY(-1px);
			}

			/* About */
			.about-grid {
				display: grid;
				grid-template-columns: 1.5fr 1fr;
				gap: var(--s-12);
				margin-top: var(--s-8);
				align-items: start;
			}
			.skill-tags {
				display: flex;
				flex-wrap: wrap;
				gap: var(--s-3);
				margin-top: var(--s-4);
			}
			.skill-tag {
				position: relative;
				display: inline-flex;
				align-items: center;
				gap: var(--s-2);
				padding: var(--s-2) var(--s-4);
				background: transparent;
				border: 1px solid var(--border-color);
				border-radius: 100px;
				font-size: 0.85rem;
				color: var(--text-secondary);
				transition:
					border-color var(--transition-fast),
					color var(--transition-fast),
					box-shadow var(--transition-fast);
				overflow: hidden;
				z-index: 1;
			}
			.skill-tag:hover {
				border-color: transparent;
				color: var(--text-primary);
				box-shadow: 0 0 12px var(--accent-glow);
			}
			.skill-tag::after {
				content: "";
				position: absolute;
				inset: 0;
				background: var(--bg-surface);
				border-radius: 100px;
				z-index: -1;
				transition:
					background var(--transition-fast),
					inset var(--transition-fast);
			}
			.skill-tag:hover::after {
				inset: 1.5px;
				background: var(--bg-surface-hover);
				border-radius: 98px;
			}
			.skill-tag::before {
				content: "";
				position: absolute;
				top: 50%;
				left: 50%;
				width: 180px;
				height: 180px;
				background: conic-gradient(
					from 0deg,
					transparent 70%,
					var(--accent-start) 100%
				);
				transform: translate(-50%, -50%) rotate(0deg);
				transition: opacity var(--transition-fast);
				opacity: 0;
				z-index: -2;
			}
			.skill-tag:hover::before {
				opacity: 1;
				animation: rotate-border 1.5s linear infinite;
			}
			@keyframes rotate-border {
				0% {
					transform: translate(-50%, -50%) rotate(0deg);
				}
				100% {
					transform: translate(-50%, -50%) rotate(360deg);
				}
			}
			.skill-icon {
				flex-shrink: 0;
				color: var(--text-muted);
				transition:
					color var(--transition-fast),
					transform var(--transition-fast);
			}
			.skill-tag:hover .skill-icon {
				color: var(--accent-start);
				transform: scale(1.1);
			}

			/* Projects */
			.projects-grid {
				display: grid;
				grid-template-columns: repeat(
					auto-fit,
					minmax(min(100%, 340px), 1fr)
				);
				gap: var(--s-8);
				margin-top: var(--s-12);
			}
			.project-card {
				height: 100%;
				display: flex;
				flex-direction: column;
				text-decoration: none;
				color: inherit;
			}
			.project-image {
				height: 220px;
				width: 100%;
				opacity: 0.9;
				transition: opacity var(--transition-base);
				position: relative;
			}
			.project-card:hover .project-image {
				opacity: 1;
			}
			.project-content {
				padding: var(--s-6);
				display: flex;
				flex-direction: column;
				flex-grow: 1;
			}
			.project-tags {
				display: flex;
				gap: var(--s-2);
				margin: var(--s-4) 0;
				flex-wrap: wrap;
			}
			.project-tags span {
				font-size: 0.7rem;
				padding: var(--s-1) var(--s-3);
				background: var(--bg-secondary);
				border: 1px solid var(--border-color);
				color: var(--text-muted);
				border-radius: 6px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.project-link {
				margin-top: auto;
				font-weight: 700;
				font-size: 0.9rem;
				display: inline-flex;
				align-items: center;
				gap: var(--s-1-5);
				color: var(--accent-start);
				transition: color var(--transition-fast);
			}
			.link-icon {
				transition: transform var(--transition-fast);
			}
			.project-card:hover .project-link {
				color: var(--accent-end);
			}
			.project-card:hover .link-icon {
				transform: translateX(4px);
			}

			/* Contact */
			.contact-card {
				margin-top: var(--s-12);
				padding: var(--s-10) var(--s-12);
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: var(--s-8);
			}
			.contact-card-content {
				text-align: left;
			}
			.contact-card h3 {
				font-size: clamp(1.5rem, 4vw, 2.25rem);
				margin-bottom: var(--s-2);
			}
			.contact-card p {
				margin-bottom: 0;
				max-width: 60ch;
			}
			.contact-card .btn {
				flex-shrink: 0;
			}

			@media (max-width: 768px) {
				.contact-card {
					flex-direction: column;
					text-align: center;
					padding: var(--s-8) var(--s-6);
					gap: var(--s-6);
				}
				.contact-card-content {
					text-align: center;
				}
				.about-grid {
					grid-template-columns: 1fr;
					gap: var(--s-8);
				}
				.hero-actions {
					flex-direction: column;
				}
				.btn {
					width: 100%;
				}
				.section {
					padding-top: var(--s-12);
					padding-bottom: var(--s-12);
				}
			}

			/* ===== Experience Section ===== */
			.experience-timeline {
				position: relative;
				margin-top: var(--s-10);
				display: flex;
				flex-direction: column;
				gap: var(--s-6);
				width: 100%;
			}
			/* Vertical line */
			.experience-timeline::before {
				content: '';
				position: absolute;
				left: 8px;
				top: var(--s-6);
				bottom: var(--s-6);
				width: 2px;
				background: linear-gradient(to bottom, var(--accent-start) 0%, var(--border-color) 100%);
			}
			.timeline-item {
				position: relative;
				padding-left: 2.25rem;
			}
			.timeline-badge {
				position: absolute;
				left: 3px;
				top: 1.6rem;
				width: 12px;
				height: 12px;
				border-radius: 50%;
				background: var(--bg-primary);
				border: 3px solid var(--accent-start);
				box-shadow: 0 0 8px var(--accent-start);
				z-index: 2;
			}
			.timeline-content {
				padding: var(--s-8);
				border-radius: var(--radius-lg);
				background: transparent;
				border: 1px solid transparent;
				transition: background-color var(--transition-base), border-color var(--transition-base), transform var(--transition-base);
			}
			.timeline-content:hover {
				border-color: var(--border-color);
				background: var(--bg-surface);
				transform: translateY(-2px);
			}
			.experience-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				flex-wrap: wrap;
				gap: var(--s-3);
				margin-bottom: var(--s-3);
			}
			.experience-header .title-group h3 {
				font-size: 1.4rem;
				font-weight: 750;
				color: var(--text-primary);
				margin-bottom: var(--s-1);
			}
			.experience-header .role {
				display: inline-block;
				font-size: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				color: var(--accent-start);
				font-weight: 700;
			}
			.experience-header .duration {
				font-size: 0.9rem;
				color: var(--text-muted);
				font-weight: 500;
			}
			.experience-desc {
				font-size: 1.05rem;
				line-height: 1.6;
				color: var(--text-secondary);
				margin-bottom: var(--s-4);
			}
			.experience-tags {
				display: flex;
				flex-wrap: wrap;
				gap: var(--s-2);
			}
			.experience-tags span {
				font-size: 0.75rem;
				font-weight: 600;
				background: var(--bg-elevated);
				border: 1px solid var(--border-color);
				padding: var(--s-1) var(--s-3);
				border-radius: var(--radius-sm);
				color: var(--text-muted);
				transition: color var(--transition-fast), border-color var(--transition-fast);
			}
			.timeline-content:hover .experience-tags span {
				color: var(--text-secondary);
				border-color: var(--border-color-hover);
			}
			@media (max-width: 600px) {
				.experience-header {
					flex-direction: column;
					gap: var(--s-1);
				}
				.timeline-item {
					padding-left: 1.75rem;
				}
				.experience-timeline::before {
					left: 4px;
				}
				.timeline-badge {
					left: -1px;
				}
				.timeline-content {
					padding: var(--s-6) var(--s-4);
				}
			}
		</style>
	</body>
</html>
