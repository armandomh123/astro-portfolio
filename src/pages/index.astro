---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION, PROJECTS, SKILLS, NAME } from "../consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		
		<main>
			<!-- Hero Section -->
			<section id="hero" class="section container">
				<div class="reveal">
					<span class="section-label">Bienvenido</span>
					<h1>Hola, soy <span class="gradient-text">{NAME}</span></h1>
					<p class="hero-description">
						Desarrollador Full Stack enfocado en crear productos digitales 
						con interfaces intuitivas y código escalable.
					</p>
					<div class="hero-actions">
						<a href="#projects" class="btn btn-primary">Ver proyectos</a>
						<a href="#contact" class="btn btn-secondary">Contactar</a>
					</div>
				</div>
			</section>

			<!-- About Section -->
			<section id="about" class="section container">
				<div class="reveal">
					<span class="section-label">Sobre mí</span>
					<h2 class="section-title">Pasión por la tecnología</h2>
					<div class="about-grid">
						<div class="about-text">
							<p>
								Llevo años explorando el ecosistema web, desde el diseño de UI 
								hasta la arquitectura de bases de datos. Me apasiona resolver 
								problemas complejos mediante soluciones simples y elegantes.
							</p>
							<p>
								Mi enfoque se centra en el rendimiento, la accesibilidad y la 
								experiencia del usuario final.
							</p>
						</div>
						<div class="about-skills">
							<h3>Skills</h3>
							<div class="skill-tags">
								{SKILLS.map(skill => <span class="skill-tag">{skill}</span>)}
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Projects Section -->
			<section id="projects" class="section container">
				<div class="reveal">
					<span class="section-label">Proyectos</span>
					<h2 class="section-title">Trabajo reciente</h2>
					<p class="section-subtitle">Una selección de proyectos en los que he trabajado últimamente.</p>
					
					<div class="projects-grid">
						{PROJECTS.map(project => (
							<div class="project-card surface-card">
								<div class="project-image" style={`background: ${project.gradient}`}></div>
								<div class="project-content">
									<h3>{project.title}</h3>
									<p>{project.description}</p>
									<div class="project-tags">
										{project.tags.map(tag => <span>{tag}</span>)}
									</div>
									<a href={project.link} class="project-link">Ver más →</a>
								</div>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- Contact Section -->
			<section id="contact" class="section container">
				<div class="reveal">
					<span class="section-label">Contacto</span>
					<h2 class="section-title">¿Tienes un proyecto en mente?</h2>
					<p class="section-subtitle">Estoy disponible para nuevos proyectos o colaboraciones.</p>
					
					<div class="contact-card surface-card">
						<h3>Hablemos</h3>
						<p>No dudes en enviarme un mensaje si quieres charlar sobre tecnología o nuevas oportunidades.</p>
						<a href="mailto:contacto@example.com" class="btn btn-primary">Enviar Email</a>
					</div>
				</div>
			</section>
		</main>

		<Footer />

		<script>
			// Scroll Reveal Animation
			const observerOptions = {
				threshold: 0.1,
				rootMargin: "0px 0px -50px 0px"
			};

			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible');
					}
				});
			}, observerOptions);

			document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
		</script>

		<style>
			main {
				margin-top: var(--s-16);
			}
			.hero-description {
				font-size: clamp(1rem, 4vw, 1.25rem);
				max-width: 600px;
				margin-bottom: var(--s-8);
				color: var(--text-secondary);
				line-height: 1.6;
			}
			.hero-actions {
				display: flex;
				gap: var(--s-4);
				flex-wrap: wrap;
			}
			
			/* Buttons */
			.btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: var(--s-3) var(--s-8);
				border-radius: var(--radius-md);
				font-weight: 600;
				transition: all var(--transition-base);
				cursor: pointer;
				text-decoration: none;
				min-width: 160px;
			}
			.btn-primary {
				background: var(--accent-gradient);
				color: white;
				box-shadow: 0 1px 2px oklch(0.12 0.01 250 / 0.18);
			}
			.btn-primary:hover {
				transform: translateY(-1px);
				box-shadow: 0 6px 16px oklch(0.12 0.01 250 / 0.2);
				color: white;
			}
			.btn-secondary {
				background: var(--bg-surface);
				border: 1px solid var(--border-color);
				color: var(--text-primary);
			}
			.btn-secondary:hover {
				background: var(--bg-surface-hover);
				border-color: var(--border-color-hover);
				transform: translateY(-1px);
			}

			/* About */
			.about-grid {
				display: grid;
				grid-template-columns: 1.5fr 1fr;
				gap: var(--s-12);
				margin-top: var(--s-8);
			}
			.skill-tags {
				display: flex;
				flex-wrap: wrap;
				gap: var(--s-3);
				margin-top: var(--s-4);
			}
			.skill-tag {
				padding: var(--s-2) var(--s-4);
				background: var(--bg-surface);
				border: 1px solid var(--border-color);
				border-radius: 100px;
				font-size: 0.85rem;
				color: var(--text-secondary);
				transition: all var(--transition-fast);
			}
			.skill-tag:hover {
				border-color: var(--border-color-hover);
				color: var(--text-primary);
				background: var(--bg-surface-hover);
			}

			/* Projects */
			.projects-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(min(100%, 340px), 1fr));
				gap: var(--s-8);
				margin-top: var(--s-12);
			}
			.project-card {
				height: 100%;
			}
			.project-image {
				height: 220px;
				width: 100%;
				opacity: 0.9;
				transition: all var(--transition-base);
				position: relative;
			}
			.project-card:hover .project-image {
				opacity: 1;
			}
			.project-content {
				padding: var(--s-6);
				display: flex;
				flex-direction: column;
				flex-grow: 1;
			}
			.project-tags {
				display: flex;
				gap: var(--s-2);
				margin: var(--s-4) 0;
				flex-wrap: wrap;
			}
			.project-tags span {
				font-size: 0.7rem;
				padding: var(--s-1) var(--s-3);
				background: var(--bg-secondary);
				border: 1px solid var(--border-color);
				color: var(--text-muted);
				border-radius: 6px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.project-link {
				margin-top: auto;
				font-weight: 700;
				font-size: 0.9rem;
				display: inline-flex;
				align-items: center;
				gap: var(--s-1);
			}

			/* Contact */
			.contact-card {
				margin-top: var(--s-12);
				padding: var(--s-12) var(--s-6);
				text-align: center;
				max-width: 800px;
				margin-left: auto;
				margin-right: auto;
			}
			.contact-card h3 {
				font-size: clamp(1.5rem, 6vw, 2.5rem);
				margin-bottom: var(--s-4);
			}

			@media (max-width: 768px) {
				.about-grid {
					grid-template-columns: 1fr;
					gap: var(--s-8);
				}
				.hero-actions {
					flex-direction: column;
				}
				.btn {
					width: 100%;
				}
				.section {
					padding-top: var(--s-12);
					padding-bottom: var(--s-12);
				}
			}
		</style>
	</body>
</html>
